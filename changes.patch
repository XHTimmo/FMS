+    console.error('PNG Export Error:', error);
+    ElMessage.error('生成图片失败，请重试');
+  } finally {
+    if (exportTimer) {
+      window.clearInterval(exportTimer);
+      exportTimer = null;
+    }
+    setTimeout(() => {
+      exporting.value = false;
+      exportProgress.value = 0;
+    }, 500);
   }
 };
 
