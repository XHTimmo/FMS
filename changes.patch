+  if (mimeType === 'image/png') return 'png';
+  if (mimeType === 'application/pdf') return 'pdf';
+  if (['jpg', 'jpeg', 'png', 'pdf'].includes(rawExt)) return rawExt === 'jpeg' ? 'jpg' : rawExt;
